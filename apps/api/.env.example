# ============================================================
# PantryPal API - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# For production deployment, use infra/aws/sam/template.complete.yaml

# Local Development Server
PORT=8788

# Database (from RDS CloudFormation output)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/NAME?schema=pantrypal_app

# Cognito (from CloudFormation outputs)
COGNITO_REGION=your-region-here
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_APP_CLIENT_ID=your-app-client-id

# AWS Services
AWS_REGION=your-region-here

# Bedrock AI
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# S3 Buckets (from CloudFormation outputs)
CURATED_RECIPES_BUCKET=your-recipe-bucket-name
CURATED_RECIPES_PREFIX=images
S3_BUCKET_DAILY_SPECIALS=your-daily-specials-bucket
PANTRY_IMAGES_BUCKET=your-pantry-uploads-bucket
S3_BUCKET_COMMUNITY_POSTS=your-community-posts-bucket

# External APIs (optional)
UNSPLASH_ACCESS_KEY=your_key_here
DEFAULT_DISH_IMAGE_URL=default-dish.jpg

# Spoonacular (comma-separated for rotation)
SPOONACULAR_API_KEY=key1,key2,key3

# DynamoDB (from CloudFormation outputs)
DYNAMODB_TABLE_COMMUNITY=pantrypal-community-dev
