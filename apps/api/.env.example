# ============================================================
# PantryPal API - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# For production deployment, use infra/aws/sam/template.complete.yaml

# Local Development Server
PORT=8788

# Database (from RDS CloudFormation output)
DATABASE_URL=postgresql://postgres:PASSWORD@endpoint.rds.amazonaws.com:5432/postgres?schema=pantrypal_app

# Cognito (from CloudFormation outputs)
COGNITO_REGION=us-east-2
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Services
AWS_REGION=us-east-2

# Bedrock AI
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# S3 Buckets (from CloudFormation outputs)
CURATED_RECIPES_BUCKET=pantrypal-recipe-images-dev
CURATED_RECIPES_PREFIX=images
S3_BUCKET_DAILY_SPECIALS=pantrypal-daily-specials-dev
PANTRY_IMAGES_BUCKET=pantrypal-user-pantry-uploads-dev
S3_BUCKET_COMMUNITY_POSTS=pantrypal-community-posts-dev

# External APIs (optional)
UNSPLASH_ACCESS_KEY=your_key_here
DEFAULT_DISH_IMAGE_URL=https://pantrypal-daily-specials-dev.s3.us-east-2.amazonaws.com/default-dish.jpg

# Spoonacular (comma-separated for rotation)
SPOONACULAR_API_KEY=key1,key2,key3

# DynamoDB (from CloudFormation outputs)
DYNAMODB_TABLE_COMMUNITY=pantrypal-community-dev
