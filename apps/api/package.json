        "@aws-sdk/lib-dynamodb": "^3.1000.0",
        "@aws-sdk/s3-request-presigner": "^3.1000.0",
        "@prisma/client": "^6.0.0",
        "esbuild": "^0.27.3",
        "jose": "^6.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@jest/globals": "^29.7.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^25.3.3",
        "jest": "^29.7.0",
        "prisma": "^6.0.0",
        "ts-jest": "^29.1.0",
        "tsx": "^4.19.2",
        "typescript": "^5.6.0"
    }
