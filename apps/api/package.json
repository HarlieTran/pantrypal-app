{
    "name": "@pantrypal/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "scripts": {
        "dev": "tsx watch src/main.ts",
        "build": "tsc -p tsconfig.json",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
